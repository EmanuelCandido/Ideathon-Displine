<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: #F8F9FA;" stylesheets="@style.css" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.displine.LoginController">
    <children>
        <VBox maxWidth="450.0" spacing="15.0" style="-fx-background-color: #FFFFFF; -fx-padding: 40; -fx-background-radius: 8px; -fx-border-color: #E2E8F0; -fx-border-radius: 8px; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 4);">
            <children>
                <VBox spacing="4.0">
                    <children>
                        <Label text="Login" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1A202C;" />
                        <Label text="Preencha os campos para acessar" style="-fx-font-size: 14px; -fx-text-fill: #718096;" />
                    </children>
                    <VBox.margin>
                        <Insets bottom="10.0" />
                    </VBox.margin>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="E-MAIL" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #718096;" />
                        <TextField fx:id="txtEmail" promptText="Digite seu e-mail" style="-fx-background-color: #FFFFFF; -fx-border-color: #CBD5E1; -fx-border-radius: 4px; -fx-padding: 10;" />
                    </children>
                </VBox>

                <VBox spacing="5.0">
                    <children>
                        <Label text="SENHA" style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #718096;" />
                        <PasswordField fx:id="txtSenha" promptText="Digite sua senha" style="-fx-background-color: #FFFFFF; -fx-border-color: #CBD5E1; -fx-border-radius: 4px; -fx-padding: 10;" />
                    </children>
                </VBox>

                <Button fx:id="btnEntrar" maxWidth="1.7976931348623157E308" mnemonicParsing="false" onAction="#realizarLogin" text="Entrar" style="-fx-background-color: #0056C6; -fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 4px; -fx-cursor: hand;">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <HBox alignment="CENTER">
                    <children>
                        <Hyperlink onAction="#irParaCadastro" text="Não tem uma conta? Cadastre-se" style="-fx-text-fill: #0056C6; -fx-font-size: 13px;" />
                    </children>
                    <VBox.margin>
                        <Insets top="5.0" />
                    </VBox.margin>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>